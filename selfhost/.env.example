# Copy to `.env` and fill in. Required by docker-compose.yml.

# Your Telegram api_id (integer) from https://my.telegram.org → API development tools.
# Must be the SAME api_id you used when logging in with the desktop app.
TD_API_ID=

# Optional overrides (defaults shown):
# TD_PORT=8550
# TD_BIND=0.0.0.0
