{
  "$schema": "https://schema.tauri.app/config/2",
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "productName": "TeleStore",
  "version": "1.9.5",
  "identifier": "com.telestore.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TeleStore",
        "width": 1200,
        "height": 800,
        "minWidth": 1000,
        "minHeight": 700,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:* https://asset.localhost http://asset.localhost; media-src 'self' blob: http://localhost:* http://127.0.0.1:*; img-src 'self' data: blob: asset: https://asset.localhost http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' blob:; frame-src 'self' blob:; worker-src 'self' blob:;",
      "capabilities": [
        "default",
        "mobile-only"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "android": {
      "minSdkVersion": 24
    }
  }
}